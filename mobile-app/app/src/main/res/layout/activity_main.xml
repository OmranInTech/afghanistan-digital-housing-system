<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7FAFC"
    tools:context=".MainActivity">

    <!-- Top Branding Typography Block -->
    <LinearLayout
        android:id="@+id/titleContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DIGITAL HOUSING"
            android:textColor="#2D3748"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <TextView
            android:id="@+id/tvAppSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Field Sales Portal"
            android:textColor="#718096"
            android:textSize="15sp"
            android:layout_marginTop="6dp"
            android:letterSpacing="0.02" />
    </LinearLayout>

    <!-- ScrollView Wrapper to perfectly center card and manage varying phone screen sizes -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/titleContainer"
        app:layout_constraintBottom_toTopOf="@id/tvFooter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <!-- Clean Centered Login Panel Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/loginCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="28dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Agent Authorization"
                        android:textColor="#2D3748"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="24dp" />

                    <!-- Input 1: Full Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="System Username"
                        android:textColor="#4A5568"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"
                        android:textAllCaps="true" />

                    <EditText
                        android:id="@+id/etName"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="e.g., Ahmad Rahimi"
                        android:inputType="textPersonName"
                        android:textColor="#2D3748"
                        android:textColorHint="#A0AEC0"
                        android:textSize="14sp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="@android:drawable/editbox_background_normal"
                        android:layout_marginBottom="18dp" />

                    <!-- Input 2: Email -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Official Email Address"
                        android:textColor="#4A5568"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"
                        android:textAllCaps="true" />

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="username@registry.gov.af"
                        android:inputType="textEmailAddress"
                        android:textColor="#2D3748"
                        android:textColorHint="#A0AEC0"
                        android:textSize="14sp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="@android:drawable/editbox_background_normal"
                        android:layout_marginBottom="18dp" />

                    <!-- Input 3: Password -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Access Password"
                        android:textColor="#4A5568"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"
                        android:textAllCaps="true" />

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="••••••••••••"
                        android:inputType="textPassword"
                        android:textColor="#2D3748"
                        android:textColorHint="#A0AEC0"
                        android:textSize="14sp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="@android:drawable/editbox_background_normal"
                        android:layout_marginBottom="18dp" />

                    <!-- Input 4: Government Code -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Government Authorization Code"
                        android:textColor="#4A5568"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"
                        android:textAllCaps="true" />

                    <EditText
                        android:id="@+id/etGovCode"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Gov-Issued Clearance Token"
                        android:inputType="text"
                        android:textColor="#2D3748"
                        android:textColorHint="#A0AEC0"
                        android:textSize="14sp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="@android:drawable/editbox_background_normal"
                        android:layout_marginBottom="28dp" />

                    <!-- Premium Action Button -->
                    <Button
                        android:id="@+id/btnVerifyIdentity"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Verify Agent Identity"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:backgroundTint="#2B6CB0"
                        app:cornerRadius="8dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <!-- Fixed Footer Note -->
    <TextView
        android:id="@+id/tvFooter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Secured Infrastructure | Ministry Registry System"
        android:textColor="#718096"
        android:textSize="11sp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>