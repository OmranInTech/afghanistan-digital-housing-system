<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FA"
    tools:context=".MainActivity">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/titleContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="52dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Digital Housing"
            android:textColor="#0F172A"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="0.03"/>

        <TextView
            android:id="@+id/tvAppSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Agent Authentication Portal"
            android:textColor="#64748B"
            android:textSize="14sp"
            android:layout_marginTop="6dp"/>
    </LinearLayout>

    <!-- CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/titleContainer"
        app:layout_constraintBottom_toTopOf="@id/tvFooter">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="22dp"
            android:gravity="center">

            <!-- CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="22dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="26dp">

                    <!-- FORM TITLE -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sign In"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#0F172A"
                        android:layout_marginBottom="22dp"/>

                    <!-- NAME -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Name"
                        android:textSize="12sp"
                        android:textColor="#475569"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etName"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="Enter your full name"
                        android:padding="14dp"
                        android:textColor="#0F172A"
                        android:textColorHint="#94A3B8"
                        android:background="@android:drawable/edit_text"
                        android:layout_marginBottom="16dp"/>

                    <!-- EMAIL -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email"
                        android:textSize="12sp"
                        android:textColor="#475569"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="name@company.com"
                        android:inputType="textEmailAddress"
                        android:padding="14dp"
                        android:textColor="#0F172A"
                        android:textColorHint="#94A3B8"
                        android:background="@android:drawable/edit_text"
                        android:layout_marginBottom="16dp"/>

                    <!-- PASSWORD -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Password"
                        android:textSize="12sp"
                        android:textColor="#475569"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="Enter your password"
                        android:inputType="textPassword"
                        android:padding="14dp"
                        android:textColor="#0F172A"
                        android:textColorHint="#94A3B8"
                        android:background="@android:drawable/edit_text"
                        android:layout_marginBottom="16dp"/>

                    <!-- GOV CODE -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gov Code"
                        android:textSize="12sp"
                        android:textColor="#475569"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etGovCode"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="Enter government code"
                        android:inputType="text"
                        android:padding="14dp"
                        android:textColor="#0F172A"
                        android:textColorHint="#94A3B8"
                        android:background="@android:drawable/edit_text"
                        android:layout_marginBottom="22dp"/>

                    <!-- BUTTON -->
                    <Button
                        android:id="@+id/btnSignIn"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:text="Sign In"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#2563EB"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- FOOTER -->
    <TextView
        android:id="@+id/tvFooter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Digital Housing System"
        android:textSize="11sp"
        android:textColor="#94A3B8"
        android:layout_marginBottom="18dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>